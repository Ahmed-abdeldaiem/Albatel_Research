# إرسال البريد من الموقع (SMTP) — انسخ إلى .env.local واملأ القيم
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_login
SMTP_PASS=your_smtp_password_or_app_password
# للمنفذ 465 غالباً: SMTP_SECURE=true
SMTP_SECURE=false
# المرسل الظاهر (غالباً نفس SMTP_USER إن لم تضبطه)
MAIL_FROM=noreply@your-domain.com
